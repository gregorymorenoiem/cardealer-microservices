    private static List<string> ValidateRow(CsvVehicleRow row, int rowNumber)
    {
        var errors = new List<string>();

        // Required: marca
        if (string.IsNullOrWhiteSpace(row.Make))
            errors.Add("Marca es requerida");

        // Required: modelo
        if (string.IsNullOrWhiteSpace(row.Model))
            errors.Add("Modelo es requerido");

        // Required: año (1900-2030)
        if (row.Year <= 0)
            errors.Add("Año es requerido");
        else if (row.Year < 1900 || row.Year > DateTime.Now.Year + 2)
            errors.Add($"Año inválido: {row.Year}. Debe estar entre 1900 y {DateTime.Now.Year + 2}");

        // Required: precio (> 0)
        if (row.Price <= 0)
            errors.Add("Precio es requerido y debe ser mayor a 0");
        else if (row.Price > 100_000_000)
            errors.Add("Precio excede el máximo permitido (100,000,000)");

        // Required: kilometraje (>= 0)
        if (row.Mileage < 0)
            errors.Add("Kilometraje no puede ser negativo");
        else if (row.Mileage > 1_000_000)
            errors.Add("Kilometraje excede el máximo razonable (1,000,000 km)");

        // Optional VIN: validate format if provided
        if (!string.IsNullOrWhiteSpace(row.VIN))
        {
            var vinResult = VinValidationService.ValidateFormat(row.VIN);
            if (!vinResult.IsValid)
                errors.Add($"VIN inválido: {vinResult.Error}");
        }

        // Validate condition if provided
        if (!string.IsNullOrWhiteSpace(row.Condition))
        {
            var validConditions = new[] { "nuevo", "new", "usado", "used", "certificado", "certifiedpreowned", "salvage", "reconstruido", "rebuilt" };
            if (!validConditions.Contains(row.Condition.ToLowerInvariant()))
                errors.Add($"Condición inválida: '{row.Condition}'. Valores permitidos: Nuevo, Usado, Certificado, Salvage, Reconstruido");
        }

        return errors;
    }

    private async Task<Vehicle> CreateVehicleFromRow(CsvVehicleRow row, Guid sellerId, Guid dealerId)
    {
        // Build title
        var title = $"{row.Year} {row.Make} {row.Model}";

        // Map transmission string → enum
        var transmission = MapTransmission(row.Transmission);

        // Map fuel type string → enum
        var fuelType = MapFuelType(row.FuelType);

        // Map body style string → enum
        var bodyStyle = MapBodyStyle(row.BodyType);

        // Map condition string → enum
        var condition = MapCondition(row.Condition);

        // Map drive type string → enum
        var driveType = MapDriveType(row.DriveType);

        // VIN normalization
        string? normalizedVin = null;
        if (!string.IsNullOrWhiteSpace(row.VIN))
        {
            var vinResult = VinValidationService.ValidateFormat(row.VIN);
            normalizedVin = vinResult.NormalizedVin;
        }

        // Parse doors
        int doors = 4;
        if (row.Doors > 0) doors = row.Doors;

        var vehicle = new Vehicle
        {
            Title = title,
            Description = row.Description ?? string.Empty,
            Price = row.Price,
            Currency = "DOP",
            Status = VehicleStatus.Draft,
            VIN = normalizedVin,
            Make = row.Make?.Trim() ?? string.Empty,
            Model = row.Model?.Trim() ?? string.Empty,
            Year = row.Year,
            Mileage = row.Mileage,
            MileageUnit = MileageUnit.Kilometers,
            VehicleType = VehicleType.Car,
            BodyStyle = bodyStyle,
            Doors = doors,
            Seats = 5,
            FuelType = fuelType,
            Transmission = transmission,
            DriveType = driveType,
            EngineSize = row.EngineSize,
            ExteriorColor = row.Color,
            Condition = condition,
            HasCleanTitle = true,
            State = row.Province,
            Country = "DO",
            SellerId = sellerId,
            DealerId = dealerId,
            FeaturesJson = "[]",
            HomepageSections = HomepageSection.None,
        };

        var created = await _vehicleRepository.CreateAsync(vehicle);

        // Publish event (fire-and-forget)
        try
        {
            await _eventPublisher.PublishAsync(new VehicleCreatedEvent
            {
                VehicleId = created.Id,
                Make = created.Make,
                Model = created.Model,
                Year = created.Year,
                Price = created.Price,
                VIN = created.VIN ?? string.Empty,
                CreatedBy = created.SellerId,
                CreatedAt = created.CreatedAt,
            });
        }
        catch (Exception ex)
        {
            _logger.LogWarning(ex, "Failed to publish VehicleCreatedEvent for imported vehicle {VehicleId}", created.Id);
        }

        return created;
    }

    private static TransmissionType MapTransmission(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return TransmissionType.Automatic;
        return value.ToLowerInvariant() switch
        {
            "manual" => TransmissionType.Manual,
            "cvt" => TransmissionType.CVT,
            "automatica" or "automatic" or "auto" => TransmissionType.Automatic,
            "dualclutch" or "dual clutch" or "dct" => TransmissionType.DualClutch,
            _ => TransmissionType.Automatic,
        };
    }

    private static FuelType MapFuelType(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return FuelType.Gasoline;
        return value.ToLowerInvariant() switch
        {
            "diesel" => FuelType.Diesel,
            "electrico" or "electric" => FuelType.Electric,
            "hibrido" or "hybrid" => FuelType.Hybrid,
            "gas natural" or "naturalgas" or "gnv" => FuelType.NaturalGas,
            "gasolina" or "gasoline" or "gas" => FuelType.Gasoline,
            _ => FuelType.Gasoline,
        };
    }

    private static BodyStyle MapBodyStyle(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return BodyStyle.Sedan;
        return value.ToLowerInvariant() switch
        {
            "sedan" or "sedán" => BodyStyle.Sedan,
            "suv" => BodyStyle.SUV,
            "crossover" => BodyStyle.Crossover,
            "pickup" or "camioneta" or "truck" => BodyStyle.Pickup,
            "van" or "furgoneta" => BodyStyle.Van,
            "minivan" => BodyStyle.Minivan,
            "coupe" or "coupé" => BodyStyle.Coupe,
            "hatchback" => BodyStyle.Hatchback,
            "wagon" or "station wagon" => BodyStyle.Wagon,
            "convertible" or "descapotable" => BodyStyle.Convertible,
            "deportivo" or "sport" or "sports" => BodyStyle.SportsCar,
            _ => BodyStyle.Sedan,
        };
    }

    private static VehicleCondition MapCondition(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return VehicleCondition.Used;
        return value.ToLowerInvariant() switch
        {
            "nuevo" or "new" => VehicleCondition.New,
            "certificado" or "certifiedpreowned" or "certified" => VehicleCondition.CertifiedPreOwned,
            "salvage" or "salvamento" => VehicleCondition.Salvage,
            "reconstruido" or "rebuilt" => VehicleCondition.Rebuilt,
            "usado" or "used" => VehicleCondition.Used,
            _ => VehicleCondition.Used,
        };
    }

    private static Entities.DriveType MapDriveType(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return Entities.DriveType.FWD;
        return value.ToLowerInvariant() switch
        {
            "rwd" or "trasera" => Entities.DriveType.RWD,
            "awd" or "integral" => Entities.DriveType.AWD,
            "4wd" or "4x4" => Entities.DriveType.FourWD,
            "fwd" or "delantera" => Entities.DriveType.FWD,
            _ => Entities.DriveType.FWD,
        };
    }
}

