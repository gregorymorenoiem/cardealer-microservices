/// <summary>
/// Handles bulk CSV/Excel vehicle import for dealers.
/// Validates each row independently and returns per-row error reports.
/// </summary>
[ApiController]
[Route("api/vehicles/import")]
[Authorize]
[EnableRateLimiting("VehiclesPolicy")]
public class ImportController : ControllerBase
{
    private readonly ApplicationDbContext _context;
    private readonly IVehicleRepository _vehicleRepository;
    private readonly IEventPublisher _eventPublisher;
    private readonly ILogger<ImportController> _logger;

    private const int MaxRows = 1000;
    private const int MinRows = 1;

    public ImportController(
        ApplicationDbContext context,
        IVehicleRepository vehicleRepository,
        IEventPublisher eventPublisher,
        ILogger<ImportController> logger)
    {
        _context = context;
        _vehicleRepository = vehicleRepository;
        _eventPublisher = eventPublisher;
        _logger = logger;
    }

    // ═══════════════════════════════════════════════════════════════
    // POST /api/vehicles/import — Bulk CSV upload & vehicle creation
    // ═══════════════════════════════════════════════════════════════

    /// <summary>
    /// Upload a CSV file with vehicle data. Creates one listing per valid row.
    /// Returns a per-row result array with successes and detailed error messages.
    /// </summary>
    [HttpPost]
    [RequestSizeLimit(10 * 1024 * 1024)] // 10 MB max
    public async Task<ActionResult<ImportResult>> Import(IFormFile file)
    {
        if (file == null || file.Length == 0)
            return BadRequest(new { message = "No se proporcionó un archivo." });

        var extension = Path.GetExtension(file.FileName).ToLowerInvariant();
        if (extension != ".csv")
            return BadRequest(new { message = "Formato no soportado. Por favor sube un archivo .csv (puedes guardar tu Excel como CSV desde Archivo → Guardar como)." });

        // Resolve sellerId from JWT
        var resolvedSellerId = Guid.Empty;
        var userIdClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                       ?? User.FindFirst("sub")?.Value;
        if (!string.IsNullOrEmpty(userIdClaim) && Guid.TryParse(userIdClaim, out var claimsUserId))
        {
            resolvedSellerId = claimsUserId;
        }

        // Resolve dealerId from JWT claims (if dealer)
        var dealerIdClaim = User.FindFirst("dealerId")?.Value;
        Guid.TryParse(dealerIdClaim, out var resolvedDealerId);

        var results = new List<ImportRowResult>();
        var rowNumber = 0;

        try
        {
            using var stream = file.OpenReadStream();
            using var reader = new StreamReader(stream, Encoding.UTF8);
            using var csv = new CsvReader(reader, new CsvConfiguration(CultureInfo.InvariantCulture)
            {
                HasHeaderRecord = true,
                MissingFieldFound = null,
                HeaderValidated = null,
                TrimOptions = TrimOptions.Trim,
                IgnoreBlankLines = true,
            });

            // Register the class map for bilingual column headers
            csv.Context.RegisterClassMap<CsvVehicleRowMap>();

            var records = new List<CsvVehicleRow>();
            await foreach (var record in csv.GetRecordsAsync<CsvVehicleRow>())
            {
                records.Add(record);
                if (records.Count > MaxRows)
                {
                    return BadRequest(new { message = $"El archivo excede el máximo de {MaxRows} filas." });
                }
            }

            if (records.Count < MinRows)
            {
                return BadRequest(new { message = "El archivo no contiene filas de datos." });
            }

            // ── Row-by-row validation and creation ───────────────────
            foreach (var row in records)
            {
                rowNumber++;
                var errors = ValidateRow(row, rowNumber);

                if (errors.Count > 0)
                {
                    results.Add(new ImportRowResult
                    {
                        Row = rowNumber,
                        Success = false,
                        Errors = errors,
                    });
                    continue;
                }

                try
                {
                    var vehicle = await CreateVehicleFromRow(row, resolvedSellerId, resolvedDealerId);
                    results.Add(new ImportRowResult
                    {
                        Row = rowNumber,
                        Success = true,
                        VehicleId = vehicle.Id,
                        Title = vehicle.Title,
                    });
                }
                catch (Exception ex)
                {
                    _logger.LogError(ex, "Error creating vehicle from CSV row {Row}", rowNumber);
                    results.Add(new ImportRowResult
                    {
                        Row = rowNumber,
                        Success = false,
                        Errors = new List<string> { $"Error interno al crear el vehículo: {ex.Message}" },
                    });
                }
            }
        }
        catch (CsvHelper.HeaderValidationException)
        {
            return BadRequest(new { message = "El archivo CSV no tiene las columnas requeridas. Descarga la plantilla para ver el formato correcto." });
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error parsing CSV file");
            return BadRequest(new { message = $"Error al leer el archivo CSV: {ex.Message}" });
        }

        var successCount = results.Count(r => r.Success);
        var errorCount = results.Count(r => !r.Success);

        _logger.LogInformation(
            "CSV import completed: {SuccessCount} created, {ErrorCount} errors, by user {UserId}",
            successCount, errorCount, resolvedSellerId);

        return Ok(new ImportResult
        {
            Success = true,
            TotalRows = results.Count,
            SuccessCount = successCount,
            ErrorCount = errorCount,
            Results = results,
            Message = errorCount == 0
                ? $"Importación completada: {successCount} vehículos creados exitosamente."
                : $"Importación completada: {successCount} creados, {errorCount} con errores. Revisa el reporte de errores."
        });
    }

    // ═══════════════════════════════════════════════════════════════
    // GET /api/vehicles/import/template — Download CSV template
    // ═══════════════════════════════════════════════════════════════

    [HttpGet("template")]
    [AllowAnonymous]
    public IActionResult DownloadTemplate()
    {
        var csv = new StringBuilder();
        csv.AppendLine("marca,modelo,año,precio,kilometraje,descripcion,transmision,combustible,color,tipo_carroceria,condicion,provincia,vin,puertas,traccion,motor");
        csv.AppendLine("Toyota,Camry,2022,1250000,35000,\"Camry en excelente estado, full equipo\",Automatica,Gasolina,Blanco,Sedan,Usado,Santo Domingo,,4,FWD,2.5L");
        csv.AppendLine("Honda,CR-V,2023,2100000,15000,\"CRV como nueva, un solo dueño\",Automatica,Gasolina,Gris,SUV,Usado,Santiago,,4,AWD,1.5T");
        csv.AppendLine("Hyundai,Tucson,2021,1650000,42000,\"Tucson bien cuidada, mantenimiento al día\",Automatica,Gasolina,Negro,SUV,Usado,La Vega,,4,FWD,2.0L");

        var bytes = Encoding.UTF8.GetPreamble().Concat(Encoding.UTF8.GetBytes(csv.ToString())).ToArray();
        return File(bytes, "text/csv; charset=utf-8", "plantilla-importacion-okla.csv");
    }

    // ═══════════════════════════════════════════════════════════════
    // GET /api/vehicles/import/errors — Download error report CSV
    // ═══════════════════════════════════════════════════════════════

    [HttpPost("errors")]
    [AllowAnonymous]
    public IActionResult DownloadErrorReport([FromBody] ErrorReportRequest request)
    {
        if (request.Errors == null || request.Errors.Count == 0)
            return BadRequest(new { message = "No hay errores para generar el reporte." });

        var csv = new StringBuilder();
        csv.AppendLine("fila,error");
        foreach (var error in request.Errors)
        {
            // Escape quotes in error messages for CSV
            var escapedErrors = string.Join(" | ", error.Errors ?? new List<string>())
                .Replace("\"", "\"\"");
            csv.AppendLine($"{error.Row},\"{escapedErrors}\"");
        }

        var bytes = Encoding.UTF8.GetPreamble().Concat(Encoding.UTF8.GetBytes(csv.ToString())).ToArray();
        return File(bytes, "text/csv; charset=utf-8", "reporte-errores-importacion.csv");
    }

