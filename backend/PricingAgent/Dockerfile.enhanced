FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS base
WORKDIR /app
EXPOSE 8080
EXPOSE 8081

FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
ARG BUILD_CONFIGURATION=Release
WORKDIR /src

# Copiar archivos de proyecto
COPY ["PricingAgent.Api/PricingAgent.Api.csproj", "PricingAgent.Api/"]
COPY ["PricingAgent.Application/PricingAgent.Application.csproj", "PricingAgent.Application/"]
COPY ["PricingAgent.Domain/PricingAgent.Domain.csproj", "PricingAgent.Domain/"]
COPY ["PricingAgent.Infrastructure/PricingAgent.Infrastructure.csproj", "PricingAgent.Infrastructure/"]

# Restaurar dependencias
RUN dotnet restore "PricingAgent.Api/PricingAgent.Api.csproj"

# Copiar código fuente
COPY . .

# Build
WORKDIR "/src/PricingAgent.Api"
RUN dotnet build "PricingAgent.Api.csproj" -c $BUILD_CONFIGURATION -o /app/build

FROM build AS publish
ARG BUILD_CONFIGURATION=Release
RUN dotnet publish "PricingAgent.Api.csproj" -c $BUILD_CONFIGURATION -o /app/publish /p:UseAppHost=false

FROM base AS final
WORKDIR /app
COPY --from=publish /app/publish .

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

ENTRYPOINT ["dotnet", "PricingAgent.Api.dll"]