{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "_comment": "Override via env var ConnectionStrings__DefaultConnection in K8s. ${VAR} does NOT work in .NET JSON.",
    "DefaultConnection": ""
  },
  "RateLimiting": {
    "Enabled": true,
    "MaxRequests": 50,
    "WindowSeconds": 60,
    "EnableLogging": true,
    "WhitelistedIps": ["127.0.0.1"]
  },
  "ElasticSearch": {
    "ConnectionString": "http://elasticsearch:9200",
    "DefaultIndex": "Roles",
    "Enable": true
  }
}
