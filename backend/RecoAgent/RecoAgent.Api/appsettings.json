{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=recoagent;Username=postgres;Password=postgres",
    "Redis": ""
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "okla-api",
    "Audience": "okla-clients"
  },
  "Claude": {
    "ApiKey": "${CLAUDE_API_KEY}"
  },
  "Cors": {
    "AllowedOrigins": ["https://okla.com.do", "https://www.okla.com.do"]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Observability": {
    "Enabled": true,
    "Endpoint": "http://otel-collector:4317"
  },
  "ErrorService": {
    "Url": "http://errorservice:8080"
  },
  "AuditService": {
    "Enabled": true
  },
  "RabbitMQ": {
    "Host": "${RABBITMQ_HOST}",
    "Port": 5672,
    "Username": "${RABBITMQ_USER}",
    "Password": "${RABBITMQ_PASS}",
    "VirtualHost": "/"
  },
  "Database": {
    "AutoMigrate": true
  }
}
