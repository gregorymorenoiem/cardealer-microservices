[flake8]
max-line-length = 120
max-complexity = 10

# Exclusions
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    build,
    dist,
    *.egg-info,
    node_modules,
    migrations,
    # ML model weights and data
    models,
    datasets,
    # Output directories
    output*,
    input,

# Ignore rules that conflict with black formatter
extend-ignore =
    # E203: whitespace before ':' (conflicts with black)
    E203,
    # W503: line break before binary operator (conflicts with black)
    W503,
    # E501: handled by max-line-length above
    E501,

per-file-ignores =
    # Allow unused imports in __init__.py
    __init__.py:F401
