{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=searchagent;Username=postgres;Password=postgres",
    "Redis": "redis:6379"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "okla-api",
    "Audience": "okla-clients"
  },
  "Claude": {
    "ApiKey": "${CLAUDE_API_KEY}"
  },
  "Cors": {
    "AllowedOrigins": ["http://frontend-web:3000"]
  },
  "Gateway": {
    "Url": "http://gateway:8080"
  },
  "Serilog": {
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341"
        }
      }
    ]
  },
  "Observability": {
    "Enabled": true,
    "Endpoint": "http://otel-collector:4317"
  },
  "ErrorService": {
    "Url": "http://errorservice:8080"
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "Port": 5672,
    "Username": "${RABBITMQ_USER}",
    "Password": "${RABBITMQ_PASS}",
    "VirtualHost": "/"
  }
}
