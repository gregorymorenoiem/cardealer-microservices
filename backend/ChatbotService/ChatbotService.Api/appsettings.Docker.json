{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "LlmService": {
    "ServerUrl": "https://api.anthropic.com",
    "ModelId": "claude-sonnet-4-5",
    "CompletionsPath": "/v1/messages",
    "TimeoutSeconds": 120,
    "Temperature": 0.3,
    "TopP": 0.9,
    "MaxTokens": 1024,
    "CacheTtlMinutes": 30,
    "CacheEnabled": true
  },
  "Cors": {
    "AllowedOrigins": ["https://okla.com.do", "https://www.okla.com.do"]
  }
}
