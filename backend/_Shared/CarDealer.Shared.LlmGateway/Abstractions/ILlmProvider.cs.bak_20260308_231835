// =============================================================================
// LLM Gateway — Abstractions
//
// Provider-agnostic interfaces for the cascading fallback system.
// Any LLM provider (Claude, Gemini, Llama, etc.) must implement ILlmProvider.
// The gateway orchestrates fallback: Claude → Gemini → Llama → Redis Cache.
// =============================================================================

namespace CarDealer.Shared.LlmGateway.Abstractions;

/// <summary>
/// Represents a single LLM completion request (provider-agnostic).
/// </summary>
public sealed class LlmRequest
{
    /// <summary>Unique request ID for tracing and idempotency.</summary>
    public string RequestId { get; init; } = Guid.NewGuid().ToString("N");

    /// <summary>System prompt (instructions for the model).</summary>
    public string SystemPrompt { get; init; } = string.Empty;

    /// <summary>User message or query.</summary>
    public required string UserMessage { get; init; }

    /// <summary>Conversation history for multi-turn interactions.</summary>
    public IReadOnlyList<LlmMessage> History { get; init; } = [];

    /// <summary>Max tokens for the response.</summary>
    public int MaxTokens { get; init; } = 4096;

    /// <summary>Temperature (0.0–1.0). Lower = more deterministic.</summary>
    public double Temperature { get; init; } = 0.3;

    /// <summary>Optional JSON schema name hint for structured output.</summary>
    public string? ResponseFormat { get; init; }

    /// <summary>Agent/service that originated this request (for logging).</summary>
    public string CallerAgent { get; init; } = "Unknown";

    /// <summary>
    /// Dealer ID for per-dealer usage tracking and cost allocation.
    /// CONTRA #5 FIX: Required to enforce per-dealer conversation limits
    /// and track API cost per ÉLITE dealer.
    /// </summary>
    public Guid? DealerId { get; init; }

    /// <summary>Cache key override. If null, auto-generated from SystemPrompt + UserMessage.</summary>
    public string? CacheKey { get; init; }

    /// <summary>Whether to skip cache lookup and always call the LLM.</summary>
    public bool SkipCache { get; init; }

    /// <summary>Per-request cache TTL override. If null, uses the global CacheTtl from LlmGatewayOptions.</summary>
    public TimeSpan? CacheTtlOverride { get; init; }

    /// <summary>Per-request timeout override. If null, uses provider default.</summary>
    public TimeSpan? Timeout { get; init; }
}

/// <summary>
/// A single message in a conversation.
/// </summary>
public sealed class LlmMessage
{
    public required string Role { get; init; } // "user" | "assistant"
    public required string Content { get; init; }
}

/// <summary>
/// Provider-agnostic LLM response.
/// </summary>
public sealed record LlmResponse
{
    /// <summary>The model's text output.</summary>
    public required string Content { get; init; }

    /// <summary>Which provider served this response.</summary>
    public required LlmProviderType Provider { get; init; }

    /// <summary>Specific model identifier (e.g., "claude-sonnet-4-20250514").</summary>
    public required string ModelId { get; init; }

    /// <summary>Fallback level reached: 0=primary, 1=first fallback, 2=second, 3=cache.</summary>
    public int FallbackLevel { get; init; }

    /// <summary>Total latency including any fallback hops.</summary>
    public TimeSpan TotalLatency { get; init; }

    /// <summary>Latency of the provider that actually responded.</summary>
    public TimeSpan ProviderLatency { get; init; }

    /// <summary>Whether this response came from Redis cache.</summary>
    public bool FromCache { get; init; }

    /// <summary>Input tokens used (if reported by provider).</summary>
    public int InputTokens { get; init; }

    /// <summary>Output tokens used (if reported by provider).</summary>
    public int OutputTokens { get; init; }

    /// <summary>Finish reason: "end_turn", "max_tokens", "stop", etc.</summary>
    public string? StopReason { get; init; }
}

/// <summary>
/// Enumeration of supported LLM providers.
/// </summary>
public enum LlmProviderType
{
    Claude = 0,
    Gemini = 1,
    Llama = 2,
    Cache = 3
}

/// <summary>
/// Interface that every LLM provider must implement.
/// </summary>
public interface ILlmProvider
{
    /// <summary>Provider type for identification in metrics/logs.</summary>
    LlmProviderType ProviderType { get; }

    /// <summary>Display name for logs (e.g., "Claude Sonnet 4.5", "Gemini 1.5 Flash").</summary>
    string DisplayName { get; }

    /// <summary>
    /// Send a completion request. Throws <see cref="LlmProviderException"/> on transient errors
    /// (429, 500, 503) so the gateway can cascade to the next provider.
    /// </summary>
    Task<LlmResponse> CompleteAsync(LlmRequest request, CancellationToken ct = default);

    /// <summary>Check if the provider is currently healthy.</summary>
    Task<bool> IsHealthyAsync(CancellationToken ct = default);
}

/// <summary>
/// The main LLM Gateway interface — orchestrates cascade fallback.
/// </summary>
public interface ILlmGateway
{
    /// <summary>
    /// Send a request through the cascade: Claude → Gemini → Llama → Cache.
    /// Never throws to the caller; always returns a response (degraded if necessary).
    /// </summary>
    Task<LlmResponse> CompleteAsync(LlmRequest request, CancellationToken ct = default);

    /// <summary>Health status of all providers.</summary>
    Task<LlmHealthReport> GetHealthAsync(CancellationToken ct = default);
}

/// <summary>
/// Health report for all LLM providers.
/// </summary>
public sealed class LlmHealthReport
{
    public required IReadOnlyDictionary<LlmProviderType, bool> ProviderHealth { get; init; }
    public required DateTimeOffset CheckedAt { get; init; }
    public bool AllHealthy => ProviderHealth.Values.All(v => v);
}

/// <summary>
/// Exception thrown by providers on transient errors to trigger cascade fallback.
/// </summary>
public class LlmProviderException : Exception
{
    public LlmProviderType Provider { get; }
    public int? HttpStatusCode { get; }
    public bool IsTransient { get; }

    public LlmProviderException(
        LlmProviderType provider,
        string message,
        int? httpStatusCode = null,
        bool isTransient = true,
        Exception? inner = null)
        : base(message, inner)
    {
        Provider = provider;
        HttpStatusCode = httpStatusCode;
        IsTransient = isTransient;
    }
}
