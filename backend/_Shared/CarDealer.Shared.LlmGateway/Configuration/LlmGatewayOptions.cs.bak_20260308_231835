// =============================================================================
// LLM Gateway — Configuration
//
// Settings for the gateway and each provider.
// Bound from appsettings.json section "LlmGateway".
// =============================================================================

namespace CarDealer.Shared.LlmGateway.Configuration;

/// <summary>
/// Root configuration for the LLM Gateway.
/// </summary>
public sealed class LlmGatewayOptions
{
    public const string SectionName = "LlmGateway";

    /// <summary>Global timeout per provider attempt (default 500ms for fast fallback).</summary>
    public TimeSpan ProviderTimeout { get; set; } = TimeSpan.FromMilliseconds(500);

    /// <summary>Total timeout for the entire cascade (all providers + cache).</summary>
    public TimeSpan TotalTimeout { get; set; } = TimeSpan.FromSeconds(30);

    /// <summary>Whether to enable Redis cache as last resort when all providers fail.</summary>
    public bool EnableCacheFallback { get; set; } = true;

    /// <summary>TTL for cached LLM responses in Redis.</summary>
    public TimeSpan CacheTtl { get; set; } = TimeSpan.FromHours(24);

    /// <summary>Feature flag to force degraded mode (cache only, no LLM calls).</summary>
    public bool ForceDegradedMode { get; set; }

    /// <summary>Claude provider settings.</summary>
    public ClaudeProviderOptions Claude { get; set; } = new();

    /// <summary>Gemini provider settings.</summary>
    public GeminiProviderOptions Gemini { get; set; } = new();

    /// <summary>Llama provider settings.</summary>
    public LlamaProviderOptions Llama { get; set; } = new();

    /// <summary>Redis connection for the fallback cache.</summary>
    public string RedisConnectionString { get; set; } = "localhost:6379";

    /// <summary>Redis key prefix for LLM cache entries.</summary>
    public string RedisCachePrefix { get; set; } = "okla:llm:cache";

    /// <summary>API cost alert thresholds and aggressive cache mode configuration.</summary>
    public CostAlertOptions CostAlerts { get; set; } = new();
}

/// <summary>
/// Configuration for API cost monitoring and automatic cost-control measures.
/// </summary>
public sealed class CostAlertOptions
{
    /// <summary>Monthly spending in USD that triggers a warning alert to admins. Default: $300.</summary>
    public decimal WarningThresholdUsd { get; set; } = 300m;

    /// <summary>Monthly spending in USD that triggers a critical alert to the CTO. Default: $500.</summary>
    public decimal CriticalThresholdUsd { get; set; } = 500m;

    /// <summary>Monthly spending in USD that auto-activates aggressive cache mode. Default: $700.</summary>
    public decimal AggressiveCacheThresholdUsd { get; set; } = 700m;

    /// <summary>
    /// Percentage of traffic routed to Claude when aggressive cache mode is active.
    /// Default: 40% (down from 100% normal cascade).
    /// </summary>
    public int AggressiveModeClaudePercent { get; set; } = 40;

    /// <summary>
    /// Percentage of traffic routed to Gemini Flash when aggressive cache mode is active.
    /// Default: 40% (cheap alternative at $0.075/$0.30 per 1M tokens).
    /// </summary>
    public int AggressiveModeGeminiPercent { get; set; } = 40;

    /// <summary>
    /// Percentage of traffic routed to Llama local when aggressive cache mode is active.
    /// Default: 20% (free, self-hosted on DigitalOcean GPU).
    /// </summary>
    public int AggressiveModeLlamaPercent { get; set; } = 20;

    /// <summary>Whether cost tracking is enabled. Default: true.</summary>
    public bool Enabled { get; set; } = true;
}

/// <summary>
/// Claude (Anthropic) provider settings.
/// </summary>
public sealed class ClaudeProviderOptions
{
    /// <summary>Whether this provider is enabled in the cascade.</summary>
    public bool Enabled { get; set; } = true;

    /// <summary>Anthropic API key.</summary>
    public string ApiKey { get; set; } = string.Empty;

    /// <summary>API base URL.</summary>
    public string BaseUrl { get; set; } = "https://api.anthropic.com";

    /// <summary>Default model ID.</summary>
    public string Model { get; set; } = "claude-sonnet-4-20250514";

    /// <summary>API version header.</summary>
    public string ApiVersion { get; set; } = "2023-06-01";

    /// <summary>Enable prompt caching beta.</summary>
    public bool EnablePromptCaching { get; set; } = true;

    /// <summary>Per-request timeout override.</summary>
    public TimeSpan? Timeout { get; set; }
}

/// <summary>
/// Gemini (Google) provider settings.
/// </summary>
public sealed class GeminiProviderOptions
{
    /// <summary>Whether this provider is enabled in the cascade.</summary>
    public bool Enabled { get; set; } = true;

    /// <summary>Google AI API key.</summary>
    public string ApiKey { get; set; } = string.Empty;

    /// <summary>API base URL.</summary>
    public string BaseUrl { get; set; } = "https://generativelanguage.googleapis.com/v1beta";

    /// <summary>Default model ID.</summary>
    public string Model { get; set; } = "gemini-1.5-flash";

    /// <summary>Per-request timeout override.</summary>
    public TimeSpan? Timeout { get; set; }
}

/// <summary>
/// Llama (self-hosted) provider settings.
/// </summary>
public sealed class LlamaProviderOptions
{
    /// <summary>Whether this provider is enabled in the cascade.</summary>
    public bool Enabled { get; set; } = true;

    /// <summary>Self-hosted Llama server URL (DigitalOcean GPU instance).</summary>
    public string BaseUrl { get; set; } = "http://llm-server:8000";

    /// <summary>Model ID for the self-hosted Llama instance.</summary>
    public string Model { get; set; } = "llama-3.1-70b";

    /// <summary>Optional API key for the self-hosted server.</summary>
    public string? ApiKey { get; set; }

    /// <summary>Per-request timeout override (Llama can be slower).</summary>
    public TimeSpan? Timeout { get; set; } = TimeSpan.FromSeconds(15);
}
