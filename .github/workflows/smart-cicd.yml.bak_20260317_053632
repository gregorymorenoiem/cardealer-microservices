# =============================================================================
# CI/CD - OKLA Monorepo (2-Job Pipeline)
# =============================================================================
# Job 1 (ci):     Detecta cambios, build/test frontend & backend,
#                 push Docker images, integration tests.
# Job 2 (deploy): Aplica manifiestos K8s y reinicia solo los pods que cambiaron.
# =============================================================================

name: "🚀 CI/CD"

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read
  packages: write
  issues: write

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # ============================================================
  # JOB 1: CI -- Build, Test & Push Images
  # ============================================================
  ci:
    name: "🔨 CI — Build, Test & Push Images"
    runs-on: [self-hosted, macOS, ARM64]
    timeout-minutes: 90
    outputs:
      changed_services: ${{ steps.collect-changed.outputs.changed }}

    steps:
      # --- Checkout -----------------------------------------------
      - name: "📥 Checkout"
        uses: actions/checkout@v6
        with:
          fetch-depth: 2

      # --- Detect Changes -----------------------------------------
      - name: "🔍 Detect file changes"
        uses: dorny/paths-filter@v4
        id: filter
        with:
          base: ${{ github.event.before }}
          filters: |
            authservice:
              - 'backend/AuthService/**'
              - 'backend/_Shared/**'
            userservice:
              - 'backend/UserService/**'
              - 'backend/_Shared/**'
            roleservice:
              - 'backend/RoleService/**'
              - 'backend/_Shared/**'
            errorservice:
              - 'backend/ErrorService/**'
              - 'backend/_Shared/**'
            notificationservice:
              - 'backend/NotificationService/**'
              - 'backend/_Shared/**'
            vehiclessaleservice:
              - 'backend/VehiclesSaleService/**'
              - 'backend/_Shared/**'
            mediaservice:
              - 'backend/MediaService/**'
              - 'backend/_Shared/**'
            billingservice:
              - 'backend/BillingService/**'
              - 'backend/_Shared/**'
            kycservice:
              - 'backend/KYCService/**'
              - 'backend/_Shared/**'
            auditservice:
              - 'backend/AuditService/**'
              - 'backend/_Shared/**'
            idempotencyservice:
              - 'backend/IdempotencyService/**'
              - 'backend/_Shared/**'
            adminservice:
              - 'backend/AdminService/**'
              - 'backend/_Shared/**'
            contactservice:
              - 'backend/ContactService/**'
              - 'backend/_Shared/**'
            reviewservice:
              - 'backend/ReviewService/**'
              - 'backend/_Shared/**'
            dealermanagementservice:
              - 'backend/DealerManagementService/**'
              - 'backend/_Shared/**'
            dealeranalyticsservice:
              - 'backend/DealerAnalyticsService/**'
              - 'backend/_Shared/**'
            crmservice:
              - 'backend/CRMService/**'
              - 'backend/_Shared/**'
            maintenanceservice:
              - 'backend/MaintenanceService/**'
              - 'backend/_Shared/**'
            comparisonservice:
              - 'backend/ComparisonService/**'
              - 'backend/_Shared/**'
            alertservice:
              - 'backend/AlertService/**'
              - 'backend/_Shared/**'
            appointmentservice:
              - 'backend/AppointmentService/**'
              - 'backend/_Shared/**'
            marketingservice:
              - 'backend/MarketingService/**'
              - 'backend/_Shared/**'
            staffservice:
              - 'backend/StaffService/**'
              - 'backend/_Shared/**'
            reportsservice:
              - 'backend/ReportsService/**'
              - 'backend/_Shared/**'
            inventorymanagementservice:
              - 'backend/InventoryManagementService/**'
              - 'backend/_Shared/**'
            paymentservice:
              - 'backend/PaymentService/**'
              - 'backend/_Shared/**'
            aiprocessingservice:
              - 'backend/AIProcessingService/**'
              - 'backend/_Shared/**'
            vehicleintelligenceservice:
              - 'backend/VehicleIntelligenceService/**'
              - 'backend/_Shared/**'
            recommendationservice:
              - 'backend/RecommendationService/**'
              - 'backend/_Shared/**'
            leadscoringservice:
              - 'backend/LeadScoringService/**'
              - 'backend/_Shared/**'
            backgroundremovalservice:
              - 'backend/BackgroundRemovalService/**'
              - 'backend/_Shared/**'
            vehicle360processingservice:
              - 'backend/Vehicle360ProcessingService/**'
              - 'backend/_Shared/**'
            video360service:
              - 'backend/Video360Service/**'
              - 'backend/_Shared/**'
            cacheservice:
              - 'backend/CacheService/**'
              - 'backend/_Shared/**'
            messagebusservice:
              - 'backend/MessageBusService/**'
              - 'backend/_Shared/**'
            configurationservice:
              - 'backend/ConfigurationService/**'
              - 'backend/_Shared/**'
            schedulerservice:
              - 'backend/SchedulerService/**'
              - 'backend/_Shared/**'
            ratelimitingservice:
              - 'backend/RateLimitingService/**'
              - 'backend/_Shared/**'
            servicediscovery:
              - 'backend/ServiceDiscovery/**'
              - 'backend/_Shared/**'
            apidocsservice:
              - 'backend/ApiDocsService/**'
              - 'backend/_Shared/**'
            integrationservice:
              - 'backend/IntegrationService/**'
              - 'backend/_Shared/**'
            dataprotectionservice:
              - 'backend/DataProtectionService/**'
              - 'backend/_Shared/**'
            advertisingservice:
              - 'backend/AdvertisingService/**'
              - 'backend/_Shared/**'
            searchagent:
              - 'backend/SearchAgent/**'
              - 'backend/_Shared/**'
            supportagent:
              - 'backend/SupportAgent/**'
              - 'backend/_Shared/**'
            recoagent:
              - 'backend/RecoAgent/**'
              - 'backend/_Shared/**'
            chatbotservice:
              - 'backend/ChatbotService/ChatbotService.Api/**'
              - 'backend/ChatbotService/ChatbotService.Application/**'
              - 'backend/ChatbotService/ChatbotService.Domain/**'
              - 'backend/ChatbotService/ChatbotService.Infrastructure/**'
              - 'backend/ChatbotService/Dockerfile'
              - 'backend/_Shared/**'
            llm-server:
              - 'backend/ChatbotService/LlmServer/**'
            gateway:
              - 'backend/Gateway/**'
            frontend-web:
              - 'frontend/web-next/**'
            infrastructure:
              - 'k8s/**'
              - 'helm/**'
              - 'compose.yaml'
              - 'compose.*.yaml'

      # --- Frontend (only when frontend-web changed) ---------------
      - name: "📦 Setup pnpm"
        if: steps.filter.outputs.frontend-web == 'true'
        uses: pnpm/action-setup@v4
        with:
          version: 9

      - name: "📦 Setup Node.js"
        if: steps.filter.outputs.frontend-web == 'true'
        uses: actions/setup-node@v6
        with:
          node-version: "20.x"

      - name: "📦 Install frontend dependencies"
        if: steps.filter.outputs.frontend-web == 'true'
        working-directory: frontend/web-next
        run: pnpm install --frozen-lockfile

      - name: "🔍 Frontend lint"
        if: steps.filter.outputs.frontend-web == 'true'
        working-directory: frontend/web-next
        run: pnpm lint

      - name: "📝 Frontend typecheck"
        if: steps.filter.outputs.frontend-web == 'true'
        working-directory: frontend/web-next
        run: pnpm typecheck

      - name: "🧪 Frontend unit tests"
        if: steps.filter.outputs.frontend-web == 'true'
        working-directory: frontend/web-next
        env:
          CI: "true"
        run: pnpm test -- --run

      - name: "🏗️ Frontend Next.js build"
        if: steps.filter.outputs.frontend-web == 'true'
        working-directory: frontend/web-next
        run: pnpm build

      # --- Backend .NET (only when backend changed) ----------------
      - name: "🔧 Setup .NET"
        if: >-
          steps.filter.outputs.authservice == 'true' ||
          steps.filter.outputs.errorservice == 'true' ||
          steps.filter.outputs.notificationservice == 'true' ||
          steps.filter.outputs.mediaservice == 'true' ||
          steps.filter.outputs.adminservice == 'true' ||
          steps.filter.outputs.contactservice == 'true' ||
          steps.filter.outputs.gateway == 'true' ||
          steps.filter.outputs.vehiclessaleservice == 'true' ||
          steps.filter.outputs.billingservice == 'true'
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: "8.0.x"

      - name: "📦 dotnet restore"
        if: >-
          steps.filter.outputs.authservice == 'true' ||
          steps.filter.outputs.errorservice == 'true' ||
          steps.filter.outputs.notificationservice == 'true' ||
          steps.filter.outputs.mediaservice == 'true' ||
          steps.filter.outputs.adminservice == 'true' ||
          steps.filter.outputs.contactservice == 'true' ||
          steps.filter.outputs.gateway == 'true' ||
          steps.filter.outputs.vehiclessaleservice == 'true' ||
          steps.filter.outputs.billingservice == 'true'
        run: dotnet restore

      - name: "🔨 dotnet build"
        if: >-
          steps.filter.outputs.authservice == 'true' ||
          steps.filter.outputs.errorservice == 'true' ||
          steps.filter.outputs.notificationservice == 'true' ||
          steps.filter.outputs.mediaservice == 'true' ||
          steps.filter.outputs.adminservice == 'true' ||
          steps.filter.outputs.contactservice == 'true' ||
          steps.filter.outputs.gateway == 'true' ||
          steps.filter.outputs.vehiclessaleservice == 'true' ||
          steps.filter.outputs.billingservice == 'true'
        run: dotnet build --no-restore /p:TreatWarningsAsErrors=true

      - name: "🧪 Backend unit tests"
        if: >-
          steps.filter.outputs.authservice == 'true' ||
          steps.filter.outputs.errorservice == 'true' ||
          steps.filter.outputs.notificationservice == 'true' ||
          steps.filter.outputs.mediaservice == 'true' ||
          steps.filter.outputs.adminservice == 'true' ||
          steps.filter.outputs.contactservice == 'true' ||
          steps.filter.outputs.gateway == 'true' ||
          steps.filter.outputs.vehiclessaleservice == 'true' ||
          steps.filter.outputs.billingservice == 'true'
        run: >
          dotnet test --no-build
          --filter "Category!=Integration&Category!=E2E&FullyQualifiedName!~E2E&FullyQualifiedName!~IntegrationTests.&FullyQualifiedName!~.Integration."
          --logger "console;verbosity=minimal"
          --blame-hang --blame-hang-timeout 2min

      # --- macOS Keychain Fix for Docker --------------------------
      # docker/login-action uses 'docker login' which tries to save credentials
      # via docker-credential-osxkeychain on macOS, failing with
      # "User interaction is not allowed. (-25308)" on headless CI runners.
      # Fix: write the auth token directly into a custom Docker config file,
      # bypassing the credential helper entirely. DOCKER_CONFIG is then set
      # to that directory so that docker build-push-action picks up the auth.
      - name: "Disable Docker credential helper (macOS keychain fix)"
        if: github.ref == 'refs/heads/main'
        run: |
          mkdir -p /tmp/.docker.ci /tmp/.docker.helpers
          # Write a no-op credential helper using base64 to avoid YAML/heredoc parse issues.
          # The helper returns empty credentials for 'get', noop for all other commands.
          # This prevents docker-credential-osxkeychain/desktop from being consulted for
          # docker.io (which would fail on headless macOS runners with keychain locked).
          echo 'IyEvYmluL2Jhc2gKaWYgWyAiJDEiID0gImdldCIgXTsgdGhlbgogIGVjaG8gJ3siVXNlcm5hbWUiOiIiLCJTZWNyZXQiOiIifScKZmkKZXhpdCAwCg==' \
            | base64 -d > /tmp/.docker.helpers/docker-credential-none
          chmod +x /tmp/.docker.helpers/docker-credential-none
          # Add helper to PATH so Docker CLI finds 'docker-credential-none' in future steps
          echo "/tmp/.docker.helpers" >> "$GITHUB_PATH"
          # Use credHelpers dict to map docker.io lookups to our no-op helper.
          # This prevents any system credential store (osxkeychain, desktop) from being called.
          printf '{"auths":{},"credHelpers":{"docker.io":"none","index.docker.io":"none"}}' \
            > /tmp/.docker.ci/config.json
          echo "DOCKER_CONFIG=/tmp/.docker.ci" >> "$GITHUB_ENV"
          echo "No-op credential helper installed at /tmp/.docker.helpers/docker-credential-none"

      - name: "Set up Docker Buildx"
        if: github.ref == 'refs/heads/main'
        uses: docker/setup-buildx-action@v3

      - name: "Docker login to GHCR (credential-helper-free)"
        if: github.ref == 'refs/heads/main'
        env:
          GHCR_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          # DOCKER_CONFIG=/tmp/.docker.ci already set by keychain fix step above
          # Build base64 auth token (same format docker login stores internally)
          AUTH=$(printf '%s:%s' "${{ github.actor }}" "$GHCR_TOKEN" | base64 | tr -d '\n')
          # Write directly to config — no credsStore key, no credential helper, no Keychain
          printf '{"auths":{"ghcr.io":{"auth":"%s"}}}' "$AUTH" \
            > /tmp/.docker.ci/config.json
          echo "DOCKER_CONFIG=/tmp/.docker.ci" >> "$GITHUB_ENV"
          echo "Logged into ghcr.io as ${{ github.actor }} (credential-helper-free)"

      # --- Docker Build & Push (one step per service) -------------
      - name: "🐳 Build & Push AuthService"
        if: steps.filter.outputs.authservice == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend
          file: backend/AuthService/Dockerfile
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/authservice:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/authservice:latest

      - name: "🐳 Build & Push ErrorService"
        if: steps.filter.outputs.errorservice == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend
          file: backend/ErrorService/Dockerfile
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/errorservice:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/errorservice:latest

      - name: "🐳 Build & Push NotificationService"
        if: steps.filter.outputs.notificationservice == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend
          file: backend/NotificationService/Dockerfile
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/notificationservice:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/notificationservice:latest

      - name: "🐳 Build & Push VehiclesSaleService"
        if: steps.filter.outputs.vehiclessaleservice == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend
          file: backend/VehiclesSaleService/Dockerfile
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/vehiclessaleservice:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/vehiclessaleservice:latest

      - name: "🐳 Build & Push MediaService"
        if: steps.filter.outputs.mediaservice == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend
          file: backend/MediaService/Dockerfile
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/mediaservice:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/mediaservice:latest

      - name: "🐳 Build & Push AdminService"
        if: steps.filter.outputs.adminservice == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend
          file: backend/AdminService/Dockerfile
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/adminservice:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/adminservice:latest

      - name: "🐳 Build & Push ContactService"
        if: steps.filter.outputs.contactservice == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend
          file: backend/ContactService/Dockerfile
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/contactservice:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/contactservice:latest

      - name: "🐳 Build & Push ReviewService"
        if: steps.filter.outputs.reviewservice == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend
          file: backend/ReviewService/Dockerfile
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/reviewservice:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/reviewservice:latest

      - name: "🐳 Build & Push DealerManagementService"
        if: steps.filter.outputs.dealermanagementservice == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend
          file: backend/DealerManagementService/Dockerfile
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/dealermanagementservice:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/dealermanagementservice:latest

      - name: "🐳 Build & Push Gateway"
        if: steps.filter.outputs.gateway == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend
          file: backend/Gateway/Dockerfile
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/gateway:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/gateway:latest

      - name: "🐳 Build & Push ChatbotService"
        if: steps.filter.outputs.chatbotservice == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend
          file: backend/ChatbotService/Dockerfile
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/chatbotservice:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/chatbotservice:latest

      - name: "🐳 Build & Push LLM Server"
        if: steps.filter.outputs.llm-server == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: backend/ChatbotService/LlmServer
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/llm-server:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/llm-server:latest

      - name: "🐳 Build & Push Frontend Web"
        if: steps.filter.outputs.frontend-web == 'true' && github.ref == 'refs/heads/main'
        uses: docker/build-push-action@v6
        with:
          context: frontend/web-next
          platforms: linux/amd64
          push: true
          tags: ghcr.io/${{ github.repository_owner }}/frontend-web:${{ github.sha }},ghcr.io/${{ github.repository_owner }}/frontend-web:latest

      # --- Integration Tests (only on main) -----------------------
      - name: "🔧 Create CI secrets for Docker Compose"
        if: github.ref == 'refs/heads/main'
        run: |
          mkdir -p secrets
          echo "ci_test_password_123" > secrets/db_password.txt
          echo "ci_test_jwt_secret_key_abcdef123456" > secrets/jwt_secret_key.txt
          echo "ci_test_rabbitmq_pass" > secrets/rabbitmq_password.txt
          echo "ci_test_redis_pass" > secrets/redis_password.txt
          echo "ci_test_sendgrid_key" > secrets/sendgrid_api_key.txt
          echo "ci_test_twilio_sid" > secrets/twilio_account_sid.txt
          echo "ci_test_twilio_token" > secrets/twilio_auth_token.txt
          echo '{}' > secrets/firebase_service_account.json
          echo "ci_test_google_id" > secrets/google_client_id.txt
          echo "ci_test_google_secret" > secrets/google_client_secret.txt
          echo "ci_test_ms_id" > secrets/microsoft_client_id.txt
          echo "ci_test_ms_secret" > secrets/microsoft_client_secret.txt
          echo "ci_test_aws_key" > secrets/aws_access_key.txt
          echo "ci_test_aws_secret" > secrets/aws_secret_key.txt

      - name: "🐳 Start infrastructure (Docker Compose)"
        if: github.ref == 'refs/heads/main'
        run: |
          docker-compose -f compose.docker.yaml up -d postgres redis rabbitmq
          echo "Waiting for PostgreSQL..."
          for i in $(seq 1 30); do
            if docker-compose -f compose.docker.yaml exec -T postgres pg_isready -U postgres 2>/dev/null; then
              echo "PostgreSQL ready"; break
            fi
            echo "  Attempt $i/30..."; sleep 5
          done
          sleep 15

      - name: "🔗 Run integration tests"
        if: github.ref == 'refs/heads/main'
        run: |
          INTEGRATION_FAILURES=""
          for SERVICE in AuthService ErrorService Gateway; do
            TEST_DIR="backend/$SERVICE/${SERVICE}.Tests"
            if [ -d "$TEST_DIR" ]; then
              echo "Running integration tests for $SERVICE..."
              cd "backend/$SERVICE"
              dotnet test --filter "Category=Integration|Category=E2E" \
                --configuration Release \
                --logger "console;verbosity=minimal" \
                --blame-hang --blame-hang-timeout 3min \
                2>&1 || {
                  echo "$SERVICE integration tests failed"
                  INTEGRATION_FAILURES="$INTEGRATION_FAILURES $SERVICE"
                }
              cd ../..
            fi
          done
          if [ -n "$INTEGRATION_FAILURES" ]; then
            echo "::error::Integration test failures:$INTEGRATION_FAILURES"
            exit 1
          fi
          echo "All integration tests passed"

      - name: "🧹 Cleanup infrastructure"
        if: always() && github.ref == 'refs/heads/main'
        run: docker-compose -f compose.docker.yaml down -v 2>/dev/null || true

      # --- Collect changed services for deploy --------------------
      - name: "📋 Collect changed services"
        id: collect-changed
        run: |
          CHANGED=""
          [ "${{ steps.filter.outputs.authservice }}" = "true" ] && CHANGED="$CHANGED authservice"
          [ "${{ steps.filter.outputs.errorservice }}" = "true" ] && CHANGED="$CHANGED errorservice"
          [ "${{ steps.filter.outputs.notificationservice }}" = "true" ] && CHANGED="$CHANGED notificationservice"
          [ "${{ steps.filter.outputs.vehiclessaleservice }}" = "true" ] && CHANGED="$CHANGED vehiclessaleservice"
          [ "${{ steps.filter.outputs.mediaservice }}" = "true" ] && CHANGED="$CHANGED mediaservice"
          [ "${{ steps.filter.outputs.adminservice }}" = "true" ] && CHANGED="$CHANGED adminservice"
          [ "${{ steps.filter.outputs.contactservice }}" = "true" ] && CHANGED="$CHANGED contactservice"
          [ "${{ steps.filter.outputs.reviewservice }}" = "true" ] && CHANGED="$CHANGED reviewservice"
          [ "${{ steps.filter.outputs.dealermanagementservice }}" = "true" ] && CHANGED="$CHANGED dealermanagementservice"
          [ "${{ steps.filter.outputs.gateway }}" = "true" ] && CHANGED="$CHANGED gateway"
          [ "${{ steps.filter.outputs.chatbotservice }}" = "true" ] && CHANGED="$CHANGED chatbotservice"
          [ "${{ steps.filter.outputs['llm-server'] }}" = "true" ] && CHANGED="$CHANGED llm-server"
          [ "${{ steps.filter.outputs['frontend-web'] }}" = "true" ] && CHANGED="$CHANGED frontend-web"
          echo "changed=$(echo $CHANGED | xargs)" >> $GITHUB_OUTPUT
          echo "Changed services:$CHANGED"

  # ============================================================
  # JOB 2: Deploy to Production
  # ============================================================
  deploy:
    name: "🚀 Deploy to Production"
    needs: ci
    if: github.ref == 'refs/heads/main' && needs.ci.result == 'success'
    runs-on: [self-hosted, macOS, ARM64]
    environment: staging

    steps:
      - name: "📥 Checkout"
        uses: actions/checkout@v6

      - name: "🔧 Install doctl"
        uses: digitalocean/action-doctl@v2
        with:
          token: ${{ secrets.DIGITALOCEAN_ACCESS_TOKEN }}

      - name: "🔐 Setup Kubernetes"
        run: doctl kubernetes cluster kubeconfig save ${{ secrets.DO_CLUSTER_NAME }}

      - name: "🚀 Deploy to Kubernetes"
        run: |
          kubectl apply -f k8s/namespace.yaml
          kubectl apply -f k8s/configmaps.yaml

          kubectl apply -f k8s/infrastructure.yaml
          echo "Waiting for PostgreSQL..."
          kubectl rollout status statefulset/postgres -n okla --timeout=180s || true
          sleep 15
          kubectl rollout status deployment/redis -n okla --timeout=60s || true
          kubectl rollout status deployment/rabbitmq -n okla --timeout=120s || true

          kubectl apply -f k8s/deployments.yaml
          kubectl apply -f k8s/services.yaml
          kubectl apply -f k8s/ingress.yaml
          kubectl apply -f k8s/chatbotservice.yaml

          echo "Restarting only changed deployments..."
          CHANGED="${{ needs.ci.outputs.changed_services }}"
          if [ -z "$(echo $CHANGED | xargs)" ]; then
            echo "No services changed -- skipping restarts"
          else
            for SVC in $CHANGED; do
              echo "  Restarting $SVC..."
              kubectl rollout restart deployment/$SVC -n okla || true
            done
            echo "Restarted $(echo $CHANGED | wc -w | tr -d ' ') services"
          fi

      - name: "✅ Verify deployment"
        run: |
          kubectl rollout status deployment/frontend-web -n okla --timeout=300s
          kubectl rollout status deployment/gateway -n okla --timeout=300s
          kubectl rollout status deployment/authservice -n okla --timeout=300s
          kubectl rollout status deployment/chatbotservice -n okla --timeout=300s || true
          kubectl rollout status deployment/llm-server -n okla --timeout=600s || true
