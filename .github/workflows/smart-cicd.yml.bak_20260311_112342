  # ============================================
  # STAGE 3: INTEGRATION TESTS
  # ============================================
  # Runs after all service CI jobs pass. Validates cross-service communication
  # using Docker Compose with PostgreSQL, Redis, and RabbitMQ.
  # A failure here blocks deployment to staging.
  # ============================================
  integration-tests:
    name: 🔗 Integration Tests
    needs:
      - authservice
      - userservice
      - roleservice
      - errorservice
      - gateway
      - frontend-web
    if: |
      always() &&
      github.ref == 'refs/heads/main' &&
      !contains(needs.*.result, 'failure')
    runs-on: [self-hosted, macOS, ARM64]
    timeout-minutes: 15

    steps:
      - name: 📥 Checkout
        uses: actions/checkout@v4

      - name: 🐳 Start infrastructure (Docker Compose)
        run: |
          echo "🚀 Starting infrastructure services..."
          docker compose -f compose.docker.yaml up -d postgres redis rabbitmq
          echo "⏳ Waiting for PostgreSQL to be healthy..."
          for i in $(seq 1 30); do
            if docker compose -f compose.docker.yaml exec -T postgres pg_isready -U postgres 2>/dev/null; then
              echo "✅ PostgreSQL is ready"
              break
            fi
            echo "  Attempt $i/30..."
            sleep 5
          done
          echo "⏳ Waiting for Redis..."
          sleep 5
          echo "⏳ Waiting for RabbitMQ..."
          sleep 10

      - name: 🔗 Run integration tests (Core services)
        run: |
          # Run integration/E2E tests for services that have them
          INTEGRATION_FAILURES=""

          for SERVICE in AuthService ErrorService Gateway; do
            TEST_DIR="backend/$SERVICE/$SERVICE.Tests"
            if [ -d "$TEST_DIR" ]; then
              echo "🧪 Running integration tests for $SERVICE..."
              cd "backend/$SERVICE"
              dotnet test --filter "Category=Integration|Category=E2E" \
                --configuration Release \
                --logger "console;verbosity=minimal" \
                --blame-hang --blame-hang-timeout 3min \
                2>&1 || {
                  echo "⚠️ $SERVICE integration tests failed"
                  INTEGRATION_FAILURES="$INTEGRATION_FAILURES $SERVICE"
                }
              cd ../..
            fi
          done

          if [ -n "$INTEGRATION_FAILURES" ]; then
            echo "::error::Integration test failures:$INTEGRATION_FAILURES"
            exit 1
          fi
          echo "✅ All integration tests passed"

      - name: 🧹 Cleanup infrastructure
        if: always()
        run: |
          docker compose -f compose.docker.yaml down -v 2>/dev/null || true

  # ============================================
  # DEPLOY TO DIGITAL OCEAN (Only on main)
  # ============================================
  deploy-staging:
    name: 🚀 Deploy to Staging
    # REMOVED continue-on-error: true — a staging deploy failure MUST block the pipeline
    # and be visible as a real failure. Silencing it hides regressions from reaching production.
    needs:
      # Integration tests gate (runs after all service CI jobs)
      - integration-tests
      # Core
      - authservice
      - userservice
      - roleservice
      - errorservice
      - notificationservice
      - vehiclessaleservice
      - mediaservice
      - billingservice
      - kycservice
      - auditservice
      - idempotencyservice
      - adminservice
      # Business
      - contactservice
      - reviewservice
      - dealermanagementservice
      - dealeranalyticsservice
      - crmservice
      - maintenanceservice
      - comparisonservice
      - alertservice
      - appointmentservice
      - marketingservice
      - staffservice
      - reportsservice
      - inventorymanagementservice
      # Payment
      - paymentservice
      # AI/ML
      - aiprocessingservice
      - vehicleintelligenceservice
      - recommendationservice
      - leadscoringservice
      - backgroundremovalservice
      - vehicle360processingservice
      - video360service
      # Infrastructure
      - cacheservice
      - messagebusservice
      - configurationservice
      - schedulerservice
      - ratelimitingservice
      - servicediscovery
      - apidocsservice
      - integrationservice
      # Compliance
      - dataprotectionservice
      # Advertising
      - advertisingservice
      # Search Agent
      - searchagent
      # Support Agent
      - supportagent
      # Recommendation Agent
      - recoagent
      # Chatbot + Gateway + Frontend
      - chatbotservice
      - gateway
      - frontend-web
    if: |
      always() && 
      github.ref == 'refs/heads/main' &&
      !contains(needs.*.result, 'failure')
    runs-on: [self-hosted, macOS, ARM64]
    environment: staging

    steps:
      - name: 📥 Checkout
        uses: actions/checkout@v4

      - name: 🔧 Install doctl
        uses: digitalocean/action-doctl@v2
        with:
          token: ${{ secrets.DIGITALOCEAN_ACCESS_TOKEN }}

      - name: 🔐 Setup Kubernetes
        run: |
          doctl kubernetes cluster kubeconfig save ${{ secrets.DO_CLUSTER_NAME }}

      - name: 🚀 Deploy to Kubernetes
        run: |
          # Apply Kubernetes manifests in order
          kubectl apply -f k8s/namespace.yaml
          kubectl apply -f k8s/configmaps.yaml

          # Deploy infrastructure (PostgreSQL + Redis + RabbitMQ)
          kubectl apply -f k8s/infrastructure.yaml

          echo "⏳ Waiting for PostgreSQL to be ready..."
          kubectl rollout status statefulset/postgres -n okla --timeout=180s || true
          sleep 15

          echo "⏳ Waiting for Redis to be ready..."
          kubectl rollout status deployment/redis -n okla --timeout=60s || true

          echo "⏳ Waiting for RabbitMQ to be ready..."
          kubectl rollout status deployment/rabbitmq -n okla --timeout=120s || true

          # Deploy services
          kubectl apply -f k8s/deployments.yaml
          kubectl apply -f k8s/services.yaml
          kubectl apply -f k8s/ingress.yaml

          # Deploy ChatbotService + LLM Server (separate manifest)
          kubectl apply -f k8s/chatbotservice.yaml

          # ⚠️ TARGETED restarts — only restart services that were actually rebuilt.
          # Blanket "kubectl rollout restart deployment -n okla" causes unnecessary pod
          # churn in 40+ services, drops in-flight requests, and resets connection pools.
          echo "🔄 Restarting only CHANGED deployments to pick up new images..."

          # Build list of changed services from job outcomes (success = was built)
          CHANGED_SERVICES=""
          ${{ needs.authservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES authservice"' || '' }}
          ${{ needs.userservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES userservice"' || '' }}
          ${{ needs.roleservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES roleservice"' || '' }}
          ${{ needs.errorservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES errorservice"' || '' }}
          ${{ needs.notificationservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES notificationservice"' || '' }}
          ${{ needs.vehiclessaleservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES vehiclessaleservice"' || '' }}
          ${{ needs.mediaservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES mediaservice"' || '' }}
          ${{ needs.billingservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES billingservice"' || '' }}
          ${{ needs.kycservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES kycservice"' || '' }}
          ${{ needs.auditservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES auditservice"' || '' }}
          ${{ needs.idempotencyservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES idempotencyservice"' || '' }}
          ${{ needs.adminservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES adminservice"' || '' }}
          ${{ needs.contactservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES contactservice"' || '' }}
          ${{ needs.reviewservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES reviewservice"' || '' }}
          ${{ needs.dealermanagementservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES dealermanagementservice"' || '' }}
          ${{ needs.chatbotservice.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES chatbotservice"' || '' }}
          ${{ needs.gateway.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES gateway"' || '' }}
          ${{ needs.frontend-web.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES frontend-web"' || '' }}
          ${{ needs.searchagent.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES searchagent"' || '' }}
          ${{ needs.supportagent.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES supportagent"' || '' }}
          ${{ needs.recoagent.result == 'success' && 'CHANGED_SERVICES="$CHANGED_SERVICES recoagent"' || '' }}

          if [ -z "$CHANGED_SERVICES" ]; then
            echo "ℹ️ No services changed — skipping restarts"
          else
            for SVC in $CHANGED_SERVICES; do
              echo "  🔄 Restarting $SVC..."
              kubectl rollout restart deployment/$SVC -n okla || true
            done
            echo "✅ Restarted $(echo $CHANGED_SERVICES | wc -w | tr -d ' ') services"
          fi

      - name: ✅ Verify deployment
        run: |
          kubectl rollout status deployment/frontend-web -n okla --timeout=300s
          kubectl rollout status deployment/gateway -n okla --timeout=300s
          kubectl rollout status deployment/authservice -n okla --timeout=300s
          kubectl rollout status deployment/chatbotservice -n okla --timeout=300s || true
          kubectl rollout status deployment/llm-server -n okla --timeout=600s || true

  # ============================================
  # SUMMARY
  # ============================================
  summary:
    name: 📊 Pipeline Summary
    needs:
      - detect-changes
      - integration-tests
      # Core
      - authservice
      - userservice
      - roleservice
      - errorservice
      - notificationservice
      - vehiclessaleservice
      - mediaservice
      - billingservice
      - kycservice
      - auditservice
      - idempotencyservice
      - adminservice
      # Business
      - contactservice
      - reviewservice
      - dealermanagementservice
      - dealeranalyticsservice
      - crmservice
      - maintenanceservice
      - comparisonservice
      - alertservice
      - appointmentservice
      - marketingservice
      - staffservice
      - reportsservice
      - inventorymanagementservice
      # Payment
      - paymentservice
      # AI/ML
      - aiprocessingservice
      - vehicleintelligenceservice
      - recommendationservice
      - leadscoringservice
      - backgroundremovalservice
      - vehicle360processingservice
      - video360service
      # Infrastructure
      - cacheservice
      - messagebusservice
      - configurationservice
      - schedulerservice
      - ratelimitingservice
      - servicediscovery
      - apidocsservice
      - integrationservice
      # Compliance
      - dataprotectionservice
      # Advertising
      - advertisingservice
      # Search Agent
      - searchagent
      # Support Agent
      - supportagent
      # Recommendation Agent
      - recoagent
      # Chatbot + Gateway + Frontend
      - chatbotservice
      - gateway
      - frontend-web
    if: always()
    runs-on: [self-hosted, macOS, ARM64]

    steps:
      - name: 📊 Generate summary
        run: |
          # Detect if any service failed
          FAILED_SERVICES=""
          ${{ contains(needs.authservice.result, 'failure') && 'FAILED_SERVICES="$FAILED_SERVICES AuthService"' || '' }}
          ${{ contains(needs.userservice.result, 'failure') && 'FAILED_SERVICES="$FAILED_SERVICES UserService"' || '' }}
          ${{ contains(needs.vehiclessaleservice.result, 'failure') && 'FAILED_SERVICES="$FAILED_SERVICES VehiclesSaleService"' || '' }}
          ${{ contains(needs.gateway.result, 'failure') && 'FAILED_SERVICES="$FAILED_SERVICES Gateway"' || '' }}
          ${{ contains(needs.frontend-web.result, 'failure') && 'FAILED_SERVICES="$FAILED_SERVICES Frontend"' || '' }}
          ${{ contains(needs.kycservice.result, 'failure') && 'FAILED_SERVICES="$FAILED_SERVICES KYCService"' || '' }}
          ${{ contains(needs.billingservice.result, 'failure') && 'FAILED_SERVICES="$FAILED_SERVICES BillingService"' || '' }}
          ${{ contains(needs.chatbotservice.result, 'failure') && 'FAILED_SERVICES="$FAILED_SERVICES ChatbotService"' || '' }}

          if [ -n "$FAILED_SERVICES" ]; then
            echo "::error::❌ CI/CD FAILURES detected:$FAILED_SERVICES"
            echo "PIPELINE_STATUS=failure" >> $GITHUB_ENV
            echo "FAILED_LIST=$FAILED_SERVICES" >> $GITHUB_ENV
          else
            echo "PIPELINE_STATUS=success" >> $GITHUB_ENV
          fi

          echo "## 🚀 CI/CD Pipeline Summary" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "### Results" >> $GITHUB_STEP_SUMMARY
          echo "| Job | Status |" >> $GITHUB_STEP_SUMMARY
          echo "|-----|--------|" >> $GITHUB_STEP_SUMMARY
          echo "| AuthService | ${{ needs.authservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| UserService | ${{ needs.userservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| RoleService | ${{ needs.roleservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| ErrorService | ${{ needs.errorservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| NotificationService | ${{ needs.notificationservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| VehiclesSaleService | ${{ needs.vehiclessaleservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| MediaService | ${{ needs.mediaservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| BillingService | ${{ needs.billingservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| KYCService | ${{ needs.kycservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| AuditService | ${{ needs.auditservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| IdempotencyService | ${{ needs.idempotencyservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| AdminService | ${{ needs.adminservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| ContactService | ${{ needs.contactservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| ReviewService | ${{ needs.reviewservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| DealerManagementService | ${{ needs.dealermanagementservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| DealerAnalyticsService | ${{ needs.dealeranalyticsservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
          echo "| CRMService | ${{ needs.crmservice.result || 'skipped' }} |" >> $GITHUB_STEP_SUMMARY
