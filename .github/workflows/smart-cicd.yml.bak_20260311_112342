      - name: 🔔 Notify on failure (Slack)
        if: env.PIPELINE_STATUS == 'failure' && env.SLACK_WEBHOOK_URL != ''
        uses: 8398a7/action-slack@v3
        with:
          status: failure
          fields: repo,message,commit,author,action,ref,workflow
          text: |
            ❌ CI/CD Pipeline FAILED
            Failed services: ${{ env.FAILED_LIST }}
            Branch: ${{ github.ref_name }}
            Commit: ${{ github.sha }}
        env:
          SLACK_WEBHOOK_URL: ${{ secrets.SLACK_WEBHOOK_URL }}
        continue-on-error: true

      - name: 🚨 Create GitHub Issue on critical failure
        if: env.PIPELINE_STATUS == 'failure' && github.ref == 'refs/heads/main'
        uses: actions/github-script@v7
        with:
          script: |
            const failedServices = process.env.FAILED_LIST || 'unknown';
            const title = `🚨 CI/CD Pipeline Failure on main — ${new Date().toISOString().slice(0,10)}`;
            const body = `## Pipeline Failure\n\n**Branch:** main\n**Commit:** ${context.sha}\n**Failed Services:** ${failedServices}\n**Run:** ${context.serverUrl}/${context.repo.owner}/${context.repo.repo}/actions/runs/${context.runId}\n\n> Auto-generated by CI/CD pipeline.`;
            await github.rest.issues.create({
              owner: context.repo.owner,
              repo: context.repo.repo,
              title: title,
              body: body,
              labels: ['ci-failure', 'priority-high']
            });
        continue-on-error: true
