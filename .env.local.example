# =============================================================================
# .env.local.example — Configuración local con paridad de producción
# =============================================================================
# Copiar a .env (ya está en .gitignore) y completar los valores reales.
# Este archivo usa los mismos nombres de variable que producción (K8s ConfigMaps).
#
# ⚠️  NUNCA commitear el archivo .env con valores reales.
# =============================================================================

# ── Entorno ──────────────────────────────────────────────────────────────────
# Usar "Production" para verificar que el código de producción funciona aquí.
# Cambiar a "Development" para Swagger + logs detallados + hot reload.
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres_dev_local_only

# ── Redis ─────────────────────────────────────────────────────────────────────
# Vacío = sin contraseña (igual que docker compose local)
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres (igual que la K8s Secret en producción)
JWT__KEY=local-dev-secret-key-minimo-32-chars-aqui

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_PASSWORD=guest

# ── OAuth — Google ───────────────────────────────────────────────────────────
# Crear credenciales en https://console.cloud.google.com → APIs → Credentials
# Authorized redirect URIs: http://localhost:15001/signin-google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ── OAuth — Microsoft ────────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=your-microsoft-app-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-app-client-secret

# ── AWS S3 (imágenes) ────────────────────────────────────────────────────────
# Usar las mismas credenciales de producción o crear un usuario IAM de dev
# con acceso solo al bucket de staging/dev
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=okla-images-dev
AWS_REGION=us-east-2

# ── IA / Claude API ───────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Pagos — Azul (sandbox) ───────────────────────────────────────────────────
AZUL_MERCHANT_ID=sandbox-merchant-id
AZUL_AUTH_KEY=sandbox-auth-key

# ── Pagos — Stripe (sandbox) ─────────────────────────────────────────────────
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# ── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ── Frontend ──────────────────────────────────────────────────────────────────
# ── URLs — Modo HTTPS con Caddy (simula producción) ──────────────────────────
# Browser hace requests a https://okla.local/api/* → Caddy → gateway:80
NEXT_PUBLIC_API_URL=https://okla.local
NEXT_PUBLIC_SITE_URL=https://okla.local
INTERNAL_API_URL=http://gateway:80

# ── URLs — Modo sin Caddy (desarrollo rápido, sin HTTPS) ─────────────────────
# Descomentar estas líneas si prefieres trabajar sin Caddy:
# NEXT_PUBLIC_API_URL=http://localhost:18443
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Frontend upstream para Caddy ─────────────────────────────────────────────
# host.docker.internal:3000 = Next.js corriendo en el host con pnpm dev
# frontend-next:3000        = Next.js corriendo dentro de Docker
FRONTEND_UPSTREAM=host.docker.internal:3000
